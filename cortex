#!/usr/bin/env bash
# @name: cortex
# @description: Top-level dispatcher for ai-synapse — routes to scripts by subcommand
# @audience: consumer
# @action: inspect
# @scope: repo
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
SCRIPTS="$REPO_ROOT/scripts"

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------

usage() {
    cat <<'EOF'
Usage: ./cortex <command> [args...]

Consumer — load and manage synapses:
  install [--force] <targets...>      Install synapses to Claude Code
  codex <targets...>                  Install synapses to Codex CLI
  codex-project <targets...>          Install synapses to Codex project
  gemini <targets...>                 Install synapses to Gemini CLI
  agents                              Install agent definitions
  identity                            Install identity files
  list                                List installed synapses
  available                           Show all available synapses
  pathway <subcommand>                Manage pathways (list, show, install, create, export)

Versioning — pin/unpin/bump/inspect synapse version:
  pin <tag|latest|main|sha:HEX>       Pin synapse to a specific version
  unpin                               Reset pin to "latest"
  bump                                Freeze floating pin to current resolved value
  status                              Show current pin, resolved SHA, drift summary
  drift <subcommand>                  Resolve drift (show, stash, restore, adopt, ignore, list-stashes)

Contributor — create and validate artifacts:
  scaffold <type> <domain> <name>     Create a new synapse (skill, agent, protocol, tool)
  validate [<path>]                   Run structural checks without committing
  test [<tool-path>]                  Run tool tests (all or targeted)

Maintainer — repo hygiene and repair:
  sync [--fix]                        Sync registries and READMEs from disk state
  audit                               Companion artifact audit
  doctor [--json|--severity-floor|--skip] Scan installed.lock for 7 finding categories
  doctor symlinks                     Check for broken symlinks (legacy behavior)
  doctor all                          Run symlinks check then full scan; combined exit
  clean                               Remove all installed symlinks
  check-links                         Validate relative markdown links
  reorganize <subcommand>             Domain-based artifact reorganization

Clerk — automated external/ submodule bumps (cron-driven):
  clerk bump-externals [--apply]      Detect upstream tags; dry-run by default
  clerk status                        Summarize ~/.synapse/clerk_state.toml
  clerk doctor                        Clerk-self checks (state, gh auth, .gitmodules)

Help:
  help [<command>]                    Show help for a command
  --version                           Show version

EOF
}

show_help() {
    local cmd="${1:-}"

    if [ -z "$cmd" ]; then
        usage
        return
    fi

    local doc="$REPO_ROOT/docs/cli/${cmd}.md"
    if [ -f "$doc" ]; then
        # Render markdown doc to terminal (plain cat — pager if available)
        if command -v less >/dev/null 2>&1; then
            less "$doc"
        else
            cat "$doc"
        fi
    else
        echo "No detailed help for '$cmd'."
        echo ""
        echo "Run './cortex help' for a list of all commands."
    fi
}

show_version() {
    echo "cortex (ai-synapse) 0.1.0"
}

# ---------------------------------------------------------------------------
# Command routing
# ---------------------------------------------------------------------------

case "${1:-}" in
    # --- Consumer: install ---
    install)        shift; "$SCRIPTS/install.sh" install "$@" ;;
    codex)          shift; "$SCRIPTS/install.sh" codex "$@" ;;
    codex-project)  shift; "$SCRIPTS/install.sh" codex-project "$@" ;;
    gemini)         shift; "$SCRIPTS/install.sh" gemini "$@" ;;
    agents)         "$SCRIPTS/install.sh" agents ;;
    identity)       "$SCRIPTS/install.sh" identity ;;

    # --- Consumer: query ---
    list)           "$SCRIPTS/install.sh" list ;;
    available)      "$SCRIPTS/install.sh" available ;;

    # --- Consumer: pathways ---
    pathway)
        shift
        if [ ! -f "$SCRIPTS/pathway.sh" ]; then
            echo "Error: pathway.sh not yet implemented"
            exit 1
        fi
        "$SCRIPTS/pathway.sh" "$@"
        ;;

    # --- Consumer: package ---
    zip)            shift; "$SCRIPTS/install.sh" zip "$@" ;;

    # --- Consumer: versioning ---
    pin)            shift; python3 "$SCRIPTS/lib/pins_cli.py" pin "$@" ;;
    unpin)          shift; python3 "$SCRIPTS/lib/pins_cli.py" unpin "$@" ;;
    bump)           shift; python3 "$SCRIPTS/lib/pins_cli.py" bump "$@" ;;
    status)         shift; python3 "$SCRIPTS/lib/pins_cli.py" status "$@" ;;

    # --- Consumer: drift resolution ---
    drift)
        shift
        sub="${1:-}"
        if [ -z "$sub" ]; then
            cat <<'DRIFTUSAGE'
Usage: ./cortex drift <subcommand> [args...]

  show <artifact>                 Show diff vs source (exit 1 if drift)
  stash <artifact> [--reason X]   Save local edits, restore canonical
  restore <stash-id> [--yes]      Restore a stash over its source path
  list-stashes [--json]           List stashes under ~/.synapse/stash/
  adopt <artifact> [--slug N] [--reason X]
                                  Promote drift to a change_request
  ignore <artifact> [--reason X] [--expires DATE]
                                  Add a [drift_exceptions] entry to pins.toml
DRIFTUSAGE
            exit 0
        fi
        shift
        python3 "$SCRIPTS/lib/drift_cli.py" "$sub" "$@"
        ;;

    # --- Contributor: create ---
    scaffold)
        shift
        if [ ! -f "$SCRIPTS/scaffold.sh" ]; then
            echo "Error: scaffold.sh not yet implemented"
            exit 1
        fi
        "$SCRIPTS/scaffold.sh" "$@"
        ;;

    # --- Contributor: test ---
    test)
        shift
        target="${1:-}"
        pass=0
        fail=0
        if [ -n "$target" ]; then
            # Targeted: run tests for one tool
            if [ ! -d "$REPO_ROOT/$target/test" ]; then
                echo "No test/ directory found in $target"
                exit 1
            fi
            tool_name="$(basename "$target")"
            echo "Testing: $tool_name"
            shopt -s nullglob
            for t in "$REPO_ROOT/$target"/test/test-*.sh; do
                if bash "$t"; then
                    pass=$((pass+1))
                else
                    fail=$((fail+1))
                fi
            done
            shopt -u nullglob
        else
            # All: discover and run all tool tests
            echo "Discovering tool tests..."
            echo ""
            shopt -s nullglob
            for test_dir in "$REPO_ROOT"/src/tools/*/test "$REPO_ROOT"/src/tools/*/*/test; do
                [ -d "$test_dir" ] || continue
                tool_dir="$(dirname "$test_dir")"
                tool_name="$(basename "$tool_dir")"
                echo "Testing: $tool_name"
                for t in "$test_dir"/test-*.sh; do
                    if bash "$t"; then
                        pass=$((pass+1))
                    else
                        fail=$((fail+1))
                    fi
                done
            done
            shopt -u nullglob
        fi
        echo ""
        echo "Test results: $pass passed, $fail failed"
        [ "$fail" -eq 0 ] && exit 0 || exit 1
        ;;

    # --- Contributor: validate ---
    validate)
        shift
        if [ ! -f "$SCRIPTS/validate.sh" ]; then
            echo "Error: validate.sh not yet implemented"
            exit 1
        fi
        "$SCRIPTS/validate.sh" "$@"
        ;;

    # --- Maintainer: repair ---
    sync)
        shift
        if [ ! -f "$SCRIPTS/sync-registry.sh" ]; then
            echo "Error: sync-registry.sh not yet implemented"
            exit 1
        fi
        "$SCRIPTS/sync-registry.sh" "$@"
        ;;

    clean)          "$SCRIPTS/install.sh" clean ;;

    # --- Maintainer: inspect ---
    audit)          "$SCRIPTS/audit-artifacts.sh" "${@:2}" ;;
    doctor)
        shift
        sub="${1:-}"
        case "$sub" in
            symlinks)
                "$SCRIPTS/install.sh" doctor-symlinks
                ;;
            all)
                shift || true
                "$SCRIPTS/install.sh" doctor-symlinks
                rc1=$?
                python3 "$SCRIPTS/lib/doctor_cli.py" "$@"
                rc2=$?
                # Combined exit code: max of the two
                exit $(( rc1 > rc2 ? rc1 : rc2 ))
                ;;
            *)
                # Default: run the new finding-based doctor with any args/flags
                python3 "$SCRIPTS/lib/doctor_cli.py" "$@"
                ;;
        esac
        ;;
    check-links)    "$SCRIPTS/check-links.sh" ;;
    reorganize)     shift; "$SCRIPTS/reorganize.sh" "$@" ;;

    # --- Clerk: external submodule bump automation ---
    clerk)
        shift
        sub="${1:-}"
        if [ -z "$sub" ]; then
            cat <<'CLERKUSAGE'
Usage: ./cortex clerk <subcommand> [args...]

  bump-externals [--apply] [--only PATH] [--state PATH] [--json]
                                  Detect upstream submodule tag bumps; default dry-run
  status [--state PATH] [--json]  Summarize clerk state file
  doctor [--state PATH]           Clerk-specific self checks
CLERKUSAGE
            exit 0
        fi
        shift
        python3 "$SCRIPTS/lib/clerk_cli.py" "$sub" "$@"
        ;;

    # --- Help ---
    help)           shift; show_help "${1:-}" ;;
    --help|-h)      usage ;;
    --version|-V)   show_version ;;
    "")             usage ;;

    *)
        echo "Unknown command: $1"
        echo ""
        usage
        exit 1
        ;;
esac
